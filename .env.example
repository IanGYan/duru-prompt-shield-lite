# Prompt Shield Lite configuration
# Copy to .env and adjust as needed.

# Core behavior
PSL_MODE=balanced

# Paths (relative to this skill repo by default if left unset)
# PSL_ROOT_DIR=/path/to/prompt-shield-lite
# PSL_RULES_DIR=/path/to/prompt-shield-lite/rules
# PSL_LOG_PATH=/path/to/prompt-shield-lite/memory/security-log.jsonl
# PSL_RL_STATE_PATH=/path/to/prompt-shield-lite/memory/psl-rate-limit.json

# Rate limit / DoS guard
PSL_RL_MAX_REQ=30
PSL_RL_WINDOW_SEC=60
PSL_RL_ACTION=block

# analyze-log safety switch: 0=only default log path, 1=allow custom paths
PSL_ALLOW_ANY_LOG_PATH=0
